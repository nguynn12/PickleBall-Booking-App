<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused State -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_white" />
            <stroke
                android:width="2dp"
                android:color="@color/green_primary" />
            <corners android:radius="@dimen/radius_12" />
            <padding
                android:bottom="@dimen/spacing_12"
                android:left="@dimen/spacing_16"
                android:right="@dimen/spacing_16"
                android:top="@dimen/spacing_12" />
        </shape>
    </item>

    <!-- Error State -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/input_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/text_tertiary" />
            <corners android:radius="@dimen/radius_12" />
            <padding
                android:bottom="@dimen/spacing_12"
                android:left="@dimen/spacing_16"
                android:right="@dimen/spacing_16"
                android:top="@dimen/spacing_12" />
        </shape>
    </item>

    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/input_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/input_stroke" />
            <corners android:radius="@dimen/radius_12" />
            <padding
                android:bottom="@dimen/spacing_12"
                android:left="@dimen/spacing_16"
                android:right="@dimen/spacing_16"
                android:top="@dimen/spacing_12" />
        </shape>
    </item>

</selector>
