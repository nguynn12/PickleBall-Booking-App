<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Application Theme: Apple-inspired, Green primary -->
    <style name="Theme.PickleBall" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/text_on_green</item>
        <item name="colorSurface">@color/bg_white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:fontFamily">@font/sf_pro_text</item>
        <item name="fontFamily">@font/sf_pro_text</item>
    </style>

    <!-- Splash Screen (pure white) -->
    <style name="Theme.PickleBall.Splash" parent="Theme.PickleBall">
        <item name="android:windowBackground">@color/bg_white</item>
        <item name="android:colorBackground">@color/bg_white</item>
    </style>

    <!-- Green Primary Button - Pill shape -->
    <style name="Widget.PickleBall.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/green_primary</item>
        <item name="android:textColor">@color/text_on_green</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="rippleColor">@color/green_dark</item>
    </style>

    <!-- Outline Button - Pill shape -->
    <style name="Widget.PickleBall.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/green_primary</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">100dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Text Input - Apple style rounded, no border at rest -->
    <style name="Widget.PickleBall.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/green_primary</item>
        <item name="boxBackgroundColor">@color/input_bg</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_tertiary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="errorIconDrawable">@null</item>
    </style>

    <!-- Material Card - Apple style (no shadow, light border) -->
    <style name="Widget.PickleBall.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_white</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardMaxElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="Base.Theme.PickleBallBookingApp"
        parent="Theme.Material3.DayNight.NoActionBar"></style>

    <!-- <style name="Base.Theme.PickleBallBookingApp"
        parent="Theme.Material3.Light.NoActionBar"></style> -->

    <!-- <style name="Base.Theme.PickleBallBookingApp"
        parent="Theme.Material3.Light.NoActionBar"></style> -->

    <!-- <style name="Base.Theme.PickleBallBookingApp"
        parent="Theme.Material3.Light.NoActionBar"></style> -->
</resources>
