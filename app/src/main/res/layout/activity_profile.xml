<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

<LinearLayout
android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="40dp">

    <!-- Header section (white) -->
<LinearLayout
android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/bg_white"
    android:paddingTop="48dp"
    android:paddingBottom="20dp"
    android:paddingLeft="20dp"
    android:paddingRight="20dp">

    <!-- Avatar Circle -->
<com.google.android.material.card.MaterialCardView
android:id="@+id/cardAvatar"
    android:layout_width="80dp"
    android:layout_height="80dp"
    app:cardCornerRadius="40dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="2dp"
    app:cardBackgroundColor="@color/green_light"
    android:layout_marginBottom="12dp">

<ImageView
android:id="@+id/imgAvatar"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scaleType="centerCrop"
    android:src="@mipmap/ic_launcher"
    android:contentDescription="Avatar"
    android:clickable="true"
    android:focusable="true"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Change Avatar -->
<TextView
android:id="@+id/tvChangeAvatar"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Đổi ảnh đại diện"
    android:textSize="15sp"
    android:textColor="@color/green_dark"
    android:fontFamily="sans-serif-medium"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground"/>

    <!-- User Name -->
<TextView
android:id="@+id/tvUserName"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Nguyễn Văn A"
    android:textSize="20sp"
    android:fontFamily="sans-serif-medium"
    android:textStyle="bold"
    android:textColor="@color/text_primary"
    android:letterSpacing="-0.01"
    android:layout_marginBottom="4dp"/>

    <!-- Role Badge (pill) -->
<com.google.android.material.card.MaterialCardView
android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="100dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/green_light">

<TextView
android:id="@+id/tvRole"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Khách hàng"
    android:textSize="13sp"
    android:fontFamily="sans-serif-medium"
    android:textColor="@color/green_dark"
    android:paddingLeft="14dp"
    android:paddingRight="14dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Nút thông báo -->
    <LinearLayout
        android:id="@+id/btnGoNotifications"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:padding="8dp"
        android:layout_marginTop="8dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_bell"
            android:layout_marginEnd="6dp"
            app:tint="@color/green_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thông báo của tôi"
            android:textSize="14sp"
            android:textColor="@color/green_primary"/>
    </LinearLayout>

    </LinearLayout>

    <!-- Section label: Personal Info -->
<TextView
android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="THÔNG TIN CÁ NHÂN"
    android:textSize="12sp"
    android:fontFamily="sans-serif-medium"
    android:textColor="@color/text_secondary"
    android:letterSpacing="0.08"
    android:layout_marginLeft="20dp"
    android:layout_marginTop="24dp"
    android:layout_marginBottom="8dp"/>

    <!-- Edit Info Card -->
<com.google.android.material.card.MaterialCardView
android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="0.5dp"
    app:cardBackgroundColor="@color/bg_white"
    android:layout_marginLeft="16dp"
    android:layout_marginRight="16dp">

<LinearLayout
android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Name Input -->
<com.google.android.material.textfield.TextInputLayout
android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:hint="Họ và tên"
    style="@style/Widget.PickleBall.TextInput"
    android:layout_marginBottom="12dp">

<com.google.android.material.textfield.TextInputEditText
android:id="@+id/edtName"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:inputType="textPersonName|textCapWords"
    android:fontFamily="sans-serif"
    android:textSize="17sp"
    android:textColor="@color/text_primary"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"/>
    </com.google.android.material.textfield.TextInputLayout>

<View android:layout_width="match_parent" android:layout_height="0.5dp"
    android:background="@color/divider" android:layout_marginBottom="10dp"/>

    <!-- Phone Input -->
<com.google.android.material.textfield.TextInputLayout
android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:hint="Số điện thoại"
    style="@style/Widget.PickleBall.TextInput"
    android:layout_marginBottom="16dp">

<com.google.android.material.textfield.TextInputEditText
android:id="@+id/edtPhone"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:inputType="phone"
    android:fontFamily="sans-serif"
    android:textSize="17sp"
    android:textColor="@color/text_primary"
    android:paddingTop="16dp"
    android:paddingBottom="16dp"/>
    </com.google.android.material.textfield.TextInputLayout>

<View android:layout_width="match_parent" android:layout_height="0.5dp"
    android:background="@color/divider" android:layout_marginBottom="10dp"/>

    <!-- Email (read-only) -->
<TextView
android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Email"
    android:textSize="12sp"
    android:fontFamily="sans-serif"
    android:textColor="@color/text_tertiary"
    android:layout_marginBottom="4dp"/>

<TextView
android:id="@+id/tvEmail"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="user@example.com"
    android:textSize="17sp"
    android:fontFamily="sans-serif"
    android:textColor="@color/text_secondary"/>

    </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Save Button -->
<com.google.android.material.button.MaterialButton
android:id="@+id/btnSaveProfile"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:text="Lưu thay đổi"
    android:textAllCaps="false"
    android:textColor="@color/white"
    android:textSize="16sp"
    style="@style/Widget.PickleBall.Button.Primary"
    android:layout_marginLeft="16dp"
    android:layout_marginRight="16dp"
    android:layout_marginTop="12dp"
    android:layout_marginBottom="20dp"/>

    <!-- Section label: Settings -->
<TextView
android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="CÀI ĐẶT"
    android:textSize="12sp"
    android:fontFamily="sans-serif-medium"
    android:textColor="@color/text_secondary"
    android:letterSpacing="0.08"
    android:layout_marginLeft="20dp"
    android:layout_marginTop="20dp"
    android:layout_marginBottom="8dp"/>

    <!-- Settings Menu Card -->
<com.google.android.material.card.MaterialCardView
android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="0.5dp"
    app:cardBackgroundColor="@color/bg_white"
    android:layout_marginLeft="16dp"
    android:layout_marginRight="16dp">

<LinearLayout
android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Change Password -->
<LinearLayout
android:id="@+id/btnChangePassword"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="20dp"
    android:paddingRight="20dp"
    android:background="?attr/selectableItemBackground">

<TextView
android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:text="Đổi mật khẩu"
    android:textSize="17sp"
    android:fontFamily="sans-serif"
    android:textColor="@color/text_primary"/>

<ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary"/>
    </LinearLayout>

<View android:layout_width="match_parent" android:layout_height="0.5dp"
    android:background="@color/divider"
    android:layout_marginLeft="20dp"/>

    <!-- Settings -->
<LinearLayout
android:id="@+id/btnSettings"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="20dp"
    android:paddingRight="20dp"
    android:background="?attr/selectableItemBackground">

<TextView
android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:text="Cài đặt"
    android:textSize="17sp"
    android:fontFamily="sans-serif"
    android:textColor="@color/text_primary"/>

<ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary"/>
    </LinearLayout>

<View android:layout_width="match_parent" android:layout_height="0.5dp"
    android:background="@color/divider"
    android:layout_marginLeft="20dp"/>

    <!-- Logout -->
<LinearLayout
android:id="@+id/btnLogout"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingLeft="20dp"
    android:paddingRight="20dp"
    android:background="?attr/selectableItemBackground">

<TextView
android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:text="Đăng xuất"
    android:textSize="17sp"
    android:fontFamily="sans-serif"
    android:textColor="@color/error_red"/>

<ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/ic_chevron_right" app:tint="@color/text_tertiary"/>
    </LinearLayout>

    </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
    </ScrollView>
