<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_white"
    android:padding="40dp">

    <!-- App Icon: Green rounded square -->
<androidx.cardview.widget.CardView
android:layout_width="96dp"
    android:layout_height="96dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/green_primary"
    android:layout_marginBottom="28dp">

<ImageView
android:layout_width="56dp"
    android:layout_height="56dp"
    android:layout_gravity="center"
    android:src="@drawable/ic_launcher_foreground"
    android:tint="@color/text_on_green"
    android:scaleType="fitCenter"
    android:contentDescription="App icon"/>
    </androidx.cardview.widget.CardView>

    <!-- App Name: "PickleBall" -->
<TextView
android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="PickleBall"
    android:textSize="32sp"
    android:textStyle="bold"
    android:fontFamily="sans-serif-medium"
    android:textColor="@color/text_primary"
    android:letterSpacing="-0.02"
    android:lineSpacingMultiplier="1.07"/>

    <!-- "Booking" in Green -->
<TextView
android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Booking"
    android:textSize="32sp"
    android:textStyle="bold"
    android:fontFamily="sans-serif-medium"
    android:textColor="@color/green_primary"
    android:letterSpacing="-0.02"
    android:lineSpacingMultiplier="1.07"
    android:layout_marginBottom="12dp"/>

    <!-- Tagline -->
<TextView
android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Đặt sân nhanh. Chơi vui vẻ"
    android:textSize="17sp"
    android:fontFamily="sans-serif"
    android:textColor="@color/text_secondary"
    android:letterSpacing="-0.02"
    android:lineSpacingMultiplier="1.47"
    android:layout_marginBottom="48dp"/>

    <!-- Loading -->
<ProgressBar
android:layout_width="32dp"
    android:layout_height="32dp"
    android:indeterminateTint="@color/green_primary"/>

    </LinearLayout>
    