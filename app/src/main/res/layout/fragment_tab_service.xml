<?xml version="1.0" encoding="utf-8"?>
<!-- Tab Dịch vụ: bảng giá sân + danh sách dịch vụ -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- BẢNG GIÁ SÂN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BẢNG GIÁ SÂN"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/green_dark"
            android:letterSpacing="0.05"
            android:layout_marginBottom="12dp"/>

        <!-- Tên loại sân -->
        <TextView
            android:id="@+id/tvPriceTableTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pickleball"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <!-- Bảng giá -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/bg_white"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header bảng -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:background="@color/bg_white"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:text="Thứ"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:background="@color/bg_primary"/>

                    <View android:layout_width="0.5dp" android:layout_height="match_parent"
                        android:background="@color/divider"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1.5"
                        android:layout_height="match_parent"
                        android:text="Khung giờ"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:background="@color/bg_primary"/>

                    <View android:layout_width="0.5dp" android:layout_height="match_parent"
                        android:background="@color/divider"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1.5"
                        android:layout_height="match_parent"
                        android:text="Giá"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:background="@color/bg_primary"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="0.5dp"
                    android:background="@color/divider"/>

                <!-- Rows bảng giá - dynamic container -->
                <LinearLayout
                    android:id="@+id/layoutPriceRows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- DANH SÁCH DỊCH VỤ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="DANH SÁCH DỊCH VỤ"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/green_dark"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xem thêm »"
                android:textSize="13sp"
                android:textColor="@color/green_primary"/>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/bg_white">

            <LinearLayout
                android:id="@+id/layoutServiceRows"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
