<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/bg_white"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Tên sân + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvManageCourtName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tên sân"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvManageStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ Chờ xác nhận"
                android:textSize="13sp"
                android:textColor="@color/warning_yellow"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/divider"
            android:layout_marginBottom="8dp"/>

        <!-- Khách hàng -->
        <TextView
            android:id="@+id/tvManageCustomer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 Khách hàng"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <!-- Ngày giờ -->
        <TextView
            android:id="@+id/tvManageDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 25/10/2025  08:00 – 10:00"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <!-- Giá -->
        <TextView
            android:id="@+id/tvManagePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 200.000đ"
            android:textSize="14sp"
            android:textColor="@color/green_dark"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Action Buttons (chỉ hiện khi pending) -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="Từ chối"
                android:textAllCaps="false"
                android:textSize="14sp"
                style="@style/Widget.PickleBall.Button.Outline"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirm"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="Xác nhận"
                android:textAllCaps="false"
                android:textSize="14sp"
                style="@style/Widget.PickleBall.Button.Primary"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
