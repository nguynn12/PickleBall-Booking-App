<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_white"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="40dp"
            android:paddingBottom="16dp"
            android:paddingHorizontal="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Thêm sân mới"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Thông tin cơ bản -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ẢNH SÂN"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <!-- Ảnh sân preview + nút chọn -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/bg_white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Preview ảnh -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardImagePreview"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/imgCourtPreview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:background="@color/green_light"
                            android:src="@drawable/ic_nav_court"
                            android:padding="40dp"
                            app:tint="@color/green_primary"/>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickImage"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="📷  Chọn ảnh sân"
                        android:textAllCaps="false"
                        android:textColor="@color/green_primary"
                        android:textSize="14sp"
                        style="@style/Widget.PickleBall.Button.Outline"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Thông tin cơ bản -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN CƠ BẢN"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/bg_white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tên sân *"
                        style="@style/Widget.PickleBall.TextInput"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtCourtName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Địa chỉ *"
                        style="@style/Widget.PickleBall.TextInput"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Số điện thoại liên hệ"
                        style="@style/Widget.PickleBall.TextInput">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Giá & Loại sân -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIÁ &amp; LOẠI SÂN"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/bg_white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Giá thuê / giờ (VNĐ) *"
                        style="@style/Widget.PickleBall.TextInput"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:paddingTop="16dp"
                            android:paddingBottom="16dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Loại sân -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loại sân"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPickleball"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pickleball"
                            android:checkable="true"
                            android:checked="true"
                            app:chipBackgroundColor="@color/green_light"
                            app:checkedIconTint="@color/green_primary"
                            android:layout_marginEnd="8dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipIndoor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trong nhà"
                            android:checkable="true"
                            app:chipBackgroundColor="@color/green_light"
                            app:checkedIconTint="@color/green_primary"
                            android:layout_marginEnd="8dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipOutdoor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngoài trời"
                            android:checkable="true"
                            app:chipBackgroundColor="@color/green_light"
                            app:checkedIconTint="@color/green_primary"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Giờ hoạt động -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIỜ HOẠT ĐỘNG"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/bg_white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Giờ mở cửa"
                            style="@style/Widget.PickleBall.TextInput">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtOpenTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="time"
                                android:text="06:00"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary"
                                android:paddingTop="16dp"
                                android:paddingBottom="16dp"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Giờ đóng cửa"
                            style="@style/Widget.PickleBall.TextInput">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtCloseTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="time"
                                android:text="22:00"
                                android:textSize="16sp"
                                android:textColor="@color/text_primary"
                                android:paddingTop="16dp"
                                android:paddingBottom="16dp"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Mô tả -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MÔ TẢ SÂN"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/bg_white"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mô tả về sân, tiện ích..."
                    style="@style/Widget.PickleBall.TextInput">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:maxLines="6"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:paddingTop="16dp"
                        android:paddingBottom="16dp"/>
                </com.google.android.material.textfield.TextInputLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Nút lưu -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:text="Lưu thông tin"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        style="@style/Widget.PickleBall.Button.Primary"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
