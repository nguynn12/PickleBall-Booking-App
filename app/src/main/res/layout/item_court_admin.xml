<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/bg_white"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: tên sân + badge trạng thái -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvAdminCourtName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Tên sân"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvAdminCourtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang hoạt động"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_badge_green"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/divider" android:layout_marginBottom="8dp"/>

        <!-- Chủ sân -->
        <TextView
            android:id="@+id/tvAdminCourtOwner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 Chủ sân: ..."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp"/>

        <!-- Địa chỉ -->
        <TextView
            android:id="@+id/tvAdminCourtAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Địa chỉ"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="4dp"/>

        <!-- Giá + loại -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvAdminCourtPrice"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="💰 0đ/giờ"
                android:textSize="13sp"
                android:textColor="@color/green_dark"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvAdminCourtType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pickleball"
                android:textSize="12sp"
                android:textColor="@color/green_primary"
                android:background="@drawable/bg_chip_selected"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"/>
        </LinearLayout>

        <!-- Action buttons (chỉ hiện khi cần) -->
        <LinearLayout
            android:id="@+id/layoutAdminActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminDeactivate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="Vô hiệu hóa"
                android:textAllCaps="false"
                android:textColor="@color/error_red"
                android:textSize="13sp"
                style="@style/Widget.PickleBall.Button.Outline"
                app:strokeColor="@color/error_red"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminActivate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="Kích hoạt"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp"
                style="@style/Widget.PickleBall.Button.Primary"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
