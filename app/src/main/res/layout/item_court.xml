<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Ảnh sân (lớn, full width) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/imgCourtItem"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/green_light"/>

            <!-- Badge "Đơn ngày" -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvBadge1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đơn ngày"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_badge_green"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:layout_marginEnd="4dp"/>

            </LinearLayout>

            <!-- Nút yêu thích + chia sẻ góc trên phải -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnFavorite"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_heart"
                    android:padding="6dp"
                    android:background="@drawable/bg_icon_circle_white"
                    android:layout_marginEnd="6dp"
                    app:tint="@color/text_secondary"/>

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_nav_profile"
                    android:padding="6dp"
                    android:background="@drawable/bg_icon_circle_white"
                    app:tint="@color/text_secondary"/>
            </LinearLayout>

        </FrameLayout>

        <!-- Thông tin sân -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <!-- Logo sân tròn -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginEnd="10dp">

                <ImageView
                    android:id="@+id/imgCourtLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_nav_court"
                    android:padding="8dp"
                    app:tint="@color/green_primary"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tên + địa chỉ + giờ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Rating + tên sân -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:id="@+id/tvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★ 5.0"
                        android:textSize="11sp"
                        android:textColor="@color/warning_yellow"
                        android:layout_marginEnd="6dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCourtNameItem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên sân Pickleball"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginBottom="2dp"/>

                <!-- Khoảng cách + địa chỉ -->
                <TextView
                    android:id="@+id/tvLocationItem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Địa chỉ sân"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginBottom="2dp"/>

                <!-- Giờ mở cửa -->
                <TextView
                    android:id="@+id/tvOpenHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕐 06:00 - 22:00"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- Nút ĐẶT LỊCH -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBookItem"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="ĐẶT LỊCH"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:letterSpacing="0.02"
                style="@style/Widget.PickleBall.Button.Primary"
                app:cornerRadius="8dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
