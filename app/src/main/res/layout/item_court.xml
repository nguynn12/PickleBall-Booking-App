<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/bg_white"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="160dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="0dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgCourtItem"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvCourtNameItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Sân Pickleball"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="14dp"
            app:layout_constraintTop_toBottomOf="@id/imgCourtItem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvLocationItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="📍 Địa chỉ"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:layout_marginTop="3dp"
            android:layout_marginHorizontal="14dp"
            app:layout_constraintTop_toBottomOf="@id/tvCourtNameItem"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvPriceItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="150.000đ/h"
            android:textColor="@color/green_primary"
            android:textStyle="bold"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvLocationItem"
            app:layout_constraintStart_toStartOf="@id/tvLocationItem"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBookItem"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Đặt sân"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            style="@style/Widget.PickleBall.Button.Primary"
            app:cornerRadius="18dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginEnd="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvPriceItem"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
