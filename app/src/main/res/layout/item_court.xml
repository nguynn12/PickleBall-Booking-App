<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/imgCourtItem"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/tvCourtNameItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Sân Pickleball"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_title"
            android:layout_marginTop="12dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/imgCourtItem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvLocationItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="📍 Địa chỉ"
            android:textSize="13sp"
            android:textColor="@color/text_sub"
            android:layout_marginTop="4dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvCourtNameItem"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvPriceItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="150.000đ/h"
            android:textColor="@color/alobo_green"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvLocationItem"
            app:layout_constraintStart_toStartOf="@id/tvLocationItem"/>

        <Button
            android:id="@+id/btnBookItem"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:text="Đặt sân"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_primary_gradient"
            app:cornerRadius="20dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvPriceItem"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
