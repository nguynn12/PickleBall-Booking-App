<?xml version="1.0" encoding="utf-8"?>
    <!--
      Onboarding Screen: ViewPager2 + dot indicator + Next/Skip buttons
    -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_white">

    <!-- Skip button (top right) -->
<TextView
android:id="@+id/tvSkip"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Bỏ qua"
    android:textSize="15sp"
    android:fontFamily="sans-serif"
    android:textColor="@color/text_secondary"
    android:paddingTop="48dp"
    android:paddingBottom="12dp"
    android:paddingLeft="16dp"
    android:paddingRight="24dp"
    android:layout_gravity="end"/>

    <!-- ViewPager2 chiếm phần lớn màn hình -->
<androidx.viewpager2.widget.ViewPager2
android:id="@+id/viewPager"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"/>

    <!-- Dot indicator -->
<com.google.android.material.tabs.TabLayout
android:id="@+id/tabIndicator"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:layout_marginBottom="24dp"
    app:tabBackground="@drawable/tab_selector"
    app:tabGravity="center"
    app:tabIndicatorHeight="0dp"
    app:tabMaxWidth="16dp"
    app:tabMinWidth="8dp"
    app:tabPaddingStart="4dp"
    app:tabPaddingEnd="4dp"
    app:tabSelectedTextColor="@color/green_primary"
    app:tabTextColor="@color/text_tertiary"/>

    <!-- Bottom: Next button -->
<com.google.android.material.button.MaterialButton
android:id="@+id/btnNext"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:text="Tiếp theo"
    android:textAllCaps="false"
    android:textColor="@color/white"
    android:textSize="16sp"
    style="@style/Widget.PickleBall.Button.Primary"
    android:layout_marginLeft="24dp"
    android:layout_marginRight="24dp"
    android:layout_marginBottom="32dp"/>

    </LinearLayout>
