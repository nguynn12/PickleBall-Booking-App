<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PickleBall">

    <meta-data
        android:name="com.google.android.geo.API_KEY"
        android:value="${MAPS_API_KEY}" />

    <!-- SPLASH: Main launcher -->
<activity
android:name=".activity.auth.SplashActivity"
    android:exported="true"
    android:theme="@style/Theme.PickleBall.Splash">
<intent-filter>
<action android:name="android.intent.action.MAIN" />
<category android:name="android.intent.category.LAUNCHER" />
</intent-filter>
    </activity>

    <!-- ONBOARDING (chi hien lan dau) -->
<activity
android:name=".activity.auth.OnboardingActivity"
    android:exported="false" />

    <!-- AUTH -->
<activity android:name=".activity.auth.LoginActivity"
    android:exported="false"
    android:windowSoftInputMode="adjustResize" />
<activity android:name=".activity.auth.RegisterActivity"
    android:exported="false"
    android:windowSoftInputMode="adjustResize" />
<activity android:name=".activity.auth.ForgotPasswordActivity" android:exported="false" />

    <!-- HOME (3 roles) - Legacy kept for reference -->
<activity android:name=".activity.home.CustomerHomeActivity"  android:exported="false" />
<activity android:name=".activity.home.OwnerHomeActivity"     android:exported="false" />
<activity android:name=".activity.home.AdminHomeActivity"     android:exported="false" />
    <activity android:name=".activity.HomeActivity" android:exported="false" />

    <!-- MAIN ACTIVITIES WITH BOTTOM NAV (new) -->
    <activity android:name=".fragment.customer.CustomerMainActivity" android:exported="false" />
    <activity android:name=".fragment.owner.OwnerMainActivity"       android:exported="false" />
    <activity android:name=".fragment.admin.AdminMainActivity"       android:exported="false" />

    <!-- PROFILE -->
<activity android:name=".activity.profile.ProfileActivity"       android:exported="false" />
<activity android:name=".activity.profile.SettingsActivity"      android:exported="false" />

    <!-- TEST screen (giu lai de khong loi) -->
<activity android:name=".activity.MainActivity"          android:exported="false" />

    <!-- ADMIN -->
<activity android:name=".activity.admin.AdminUserListActivity" android:exported="false" />
<activity android:name=".activity.AdminDashboardActivity"      android:exported="false" />

    <!-- COURT -->
<activity android:name=".activity.court.AddCourtActivity"      android:exported="false" />
<activity android:name=".activity.court.CourtDetailActivity"   android:exported="false" />

    <!-- BOOKING -->
<activity android:name=".activity.booking.CreateBookingActivity"       android:exported="false"
    android:windowSoftInputMode="adjustResize" />
<activity android:name=".activity.booking.OwnerBookingManageActivity"  android:exported="false" />
<activity android:name=".activity.booking.BookingScheduleActivity"     android:exported="false" />
<activity android:name=".activity.booking.BookingConfirmActivity"      android:exported="false"
    android:windowSoftInputMode="adjustResize" />

    <!-- NOTIFICATIONS -->
<activity android:name=".activity.NotificationsActivity" android:exported="false" />

</application>

    </manifest>
